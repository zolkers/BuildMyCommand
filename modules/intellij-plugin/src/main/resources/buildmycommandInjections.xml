<component name="LanguageInjectionConfiguration">
    <injection language="BuildMyCommandRoute" injector-id="java">
        <display-name>BuildMyCommand annotation route DSL</display-name>
        <place><![CDATA[
            psiAnnotation("dev.riege.buildmycommand.annotation.Route")
        ]]></place>
    </injection>
    <injection language="BuildMyCommandRoute" injector-id="java">
        <display-name>BuildMyCommand annotation subroute DSL</display-name>
        <place><![CDATA[
            psiAnnotation("dev.riege.buildmycommand.annotation.SubRoute")
        ]]></place>
    </injection>
    <injection language="BuildMyCommandRoute" injector-id="java">
        <display-name>BuildMyCommand route DSL</display-name>
