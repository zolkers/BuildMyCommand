<idea-plugin>
    <id>dev.riege.buildmycommand.dsl</id>
    <name>BuildMyCommand DSL Support</name>
    <vendor>Riege</vendor>

    <description>
        Adds initial IntelliJ awareness for BuildMyCommand annotation and route DSL string literals.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>org.intellij.intelliLang</depends>
    <depends>org.jetbrains.plugins.textmate</depends>

    <extensions defaultExtensionNs="org.intellij.intelliLang">
        <injectionConfig config="buildmycommandInjections.xml"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <multiHostInjector implementation="dev.riege.buildmycommand.intellij.BuildMyCommandRouteInjector"/>
        <multiHostInjector implementation="dev.riege.buildmycommand.intellij.BuildMyCommandRequirementInjector"/>
        <multiHostInjector implementation="dev.riege.buildmycommand.intellij.BuildMyCommandPermissionRegexInjector"/>
        <implicitUsageProvider implementation="dev.riege.buildmycommand.intellij.BuildMyCommandImplicitUsageProvider"/>
        <annotator language="JAVA" implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandRouteAnnotator"/>
        <annotator language="JAVA" implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandRequirementAnnotator"/>
        <annotator language="JAVA" implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandPermissionRegexAnnotator"/>
        <completion.contributor language="BuildMyCommandRoute"
                                implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandRouteCompletionContributor"/>
        <localInspection language="JAVA"
                         shortName="BuildMyCommandRouteDsl"
                         displayName="BuildMyCommand route DSL validation"
                         groupName="BuildMyCommand"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandRouteInspection"/>
        <lang.syntaxHighlighterFactory language="BuildMyCommandRoute"
                                       implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandRouteSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="BuildMyCommandRequirement"
                                       implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandRequirementSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="BuildMyCommandPermissionRegex"
                                       implementationClass="dev.riege.buildmycommand.intellij.BuildMyCommandPermissionRegexSyntaxHighlighterFactory"/>
        <textmate.bundleProvider implementation="dev.riege.buildmycommand.intellij.BuildMyCommandTextMateBundleProvider"/>
        <additionalTextAttributes scheme="Default" file="colorSchemes/BuildMyCommandRoute.xml"/>
        <additionalTextAttributes scheme="Darcula" file="colorSchemes/BuildMyCommandRouteDarcula.xml"/>
    </extensions>
</idea-plugin>
